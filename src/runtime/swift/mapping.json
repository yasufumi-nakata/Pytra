{
  "builtin_prefix": "pytra",
  "calls": {
    "env.target": "\"swift\"",
    "print": "print",
    "py_print": "print",
    "len": "__pytra_len",
    "py_len": "__pytra_len",
    "str": "__pytra_str",
    "py_to_string": "__pytra_str",
    "int": "__pytra_int",
    "float": "__pytra_float",
    "bool": "__pytra_truthy",
    "py_bool": "__pytra_truthy",
    "py_truthy": "__pytra_truthy",
    "py_range": "__pytra_range",
    "py_floordiv": "__pytra_floordiv",
    "py_in": "__pytra_contains",
    "py_slice": "__pytra_slice",
    "bytearray": "__pytra_bytes",
    "bytes": "__pytra_bytes",
    "perf_counter": "__pytra_perf_counter",
    "sqrt": "math_native.sqrt",
    "floor": "math_native.floor",
    "time.perf_counter": "time_native.perf_counter"
  },
  "types": {
    "int": "Int64",
    "int8": "Int64",
    "uint8": "Int64",
    "int16": "Int64",
    "uint16": "Int64",
    "int32": "Int64",
    "uint32": "Int64",
    "int64": "Int64",
    "uint64": "Int64",
    "float": "Double",
    "float32": "Double",
    "float64": "Double",
    "bool": "Bool",
    "str": "String",
    "None": "Void",
    "Any": "Any",
    "Obj": "Any",
    "Path": "String",
    "Exception": "Error"
  },
  "implicit_promotions": [
    ["int8", "int64"],
    ["uint8", "int64"],
    ["int16", "int64"],
    ["uint16", "int64"],
    ["int32", "int64"],
    ["uint32", "int64"],
    ["int64", "float64"],
    ["float32", "float64"]
  ],
  "skip_modules": [
    "pytra.built_in.",
    "pytra.core.",
    "pytra.typing",
    "pytra.std.math",
    "pytra.std.time"
  ]
}
