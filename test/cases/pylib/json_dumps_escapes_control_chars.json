{
  "description": "pytra json dumps escapes control characters",
  "case": "json_dumps_escapes_control_chars",
  "assertions": [
    {"path": "quote", "equals": true},
    {"path": "backslash", "equals": true},
    {"path": "backspace", "equals": true},
    {"path": "formfeed", "equals": true},
    {"path": "newline", "equals": true},
    {"path": "carriage", "equals": true},
    {"path": "tab", "equals": true}
  ]
}
